# =============================================
# SMART MATCHER - Configuration
# =============================================

# --- Serveur ---
server.port=8081
server.address=0.0.0.0

# --- CORS ---
cors.allowed-origins=${ALLOWED_ORIGINS:http://localhost:5173,https://julienbui.dev}

# --- Profils ---
# Active le profil de développement par défaut en local
spring.profiles.active=dev

# --- JPA / Hibernate ---
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true

# --- Serveur ---
# On dit à Spring d'utiliser le port donné par Railway, et à défaut le 8080
server.port=${PORT:8080}
server.address=0.0.0.0

# --- Mistral AI ---
spring.ai.mistralai.api-key=${SPRING_AI_MISTRAL_API_KEY:}
spring.ai.mistralai.chat.options.model=open-mixtral-8x7b

# Debugging
logging.level.org.springframework.web.client=DEBUG
logging.level.org.springframework.ai.mistralai=DEBUG

# --- Upload de fichiers ---
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB

# --- Thymeleaf ---
spring.thymeleaf.prefix=classpath:/templates/
spring.thymeleaf.suffix=.html
